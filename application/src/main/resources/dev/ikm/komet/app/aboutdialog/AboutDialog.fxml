<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="170.0" prefWidth="250.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.ikm.komet.app.aboutdialog.AboutDialogController">
   <children>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Komet">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <ImageView fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@powered-by-ike-color-on-light.png" />
               </image>
               <VBox.margin>
                  <Insets bottom="10.0" top="6.0" />
               </VBox.margin>
            </ImageView>
            <HBox alignment="CENTER" spacing="2.0">
               <children>
                  <Label text="Copyright ©" />
                  <Label fx:id="copyrightYearLabel" text="year" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Version:" />
                  <Label fx:id="versionLabel" text="version" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Published Date:" />
                  <Label fx:id="publishedDateLabel" text="date" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
