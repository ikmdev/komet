<?xml version="1.0" encoding="UTF-8"?>

<?import dev.ikm.komet.kview.controls.KlWindowControlToolbar?>
<?import dev.ikm.komet.kview.controls.PublicIDListControl?>
<?import dev.ikm.komet.kview.controls.StampViewControl?>
<?import dev.ikm.komet.kview.mvvm.view.journal.VerticallyFilledPane?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>

<?import javafx.scene.control.SplitPane?>
<?import dev.ikm.komet.kview.controls.ComponentItemNode?>
<BorderPane fx:id="detailsOuterBorderPane" maxHeight="Infinity" maxWidth="Infinity" prefWidth="727.0"
            stylesheets="@../kview.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.ikm.komet.kview.mvvm.view.genpurpose.GenPurposeDetailsController">
    <top>
        <FlowPane styleClass="rounded-top">
            <children>
                <HBox fx:id="tabHeader">
                    <styleClass>
                        <String fx:value="lidr-rounded-tab"/>
                    </styleClass>
                    <children>
                        <Region styleClass="nine-dots-icon"/>
                        <Text fx:id="windowTitleLabel" strokeType="OUTSIDE" strokeWidth="0.0"
                              styleClass="lidr-tab-text"/>
                        <Label fx:id="draftChip" styleClass="draft-chip" text="DRAFT"
                               visible="false" managed="false"/>
                    </children>
                    <cursor>
                        <Cursor fx:constant="CLOSED_HAND"/>
                    </cursor>
                </HBox>
            </children>
        </FlowPane>
    </top>
    <center>
        <BorderPane fx:id="detailsCenterBorderPane" prefWidth="762.0">
            <top>
                <KlWindowControlToolbar fx:id="windowControlToolbar"/>
            </top>
            <center>
        <!-- Wraps everything below the toolbar (hint, content and the slideout trays), so the
             create-mode dashed frame drawn on it follows the window's outside edges even when
             the properties bumpout is open. The toolbar and tab carry their own darker
             create-mode dashes (see kview.css). -->
        <BorderPane styleClass="window-body-frame">
            <top>
                <Label fx:id="createModeHintLabel" styleClass="create-mode-hint"
                       maxWidth="1.7976931348623157E308" visible="false" managed="false">
                    <graphic>
                        <!-- info icon: outlined circle + dot + stem, one even-odd path -->
                        <SVGPath styleClass="create-mode-hint-icon" fillRule="EVEN_ODD"
                                 content="M6.5 0 A6.5 6.5 0 1 0 6.5 13 A6.5 6.5 0 1 0 6.5 0 Z M6.5 1.2 A5.3 5.3 0 1 1 6.5 11.8 A5.3 5.3 0 1 1 6.5 1.2 Z M6.5 2.95 A0.95 0.95 0 1 0 6.5 4.85 A0.95 0.95 0 1 0 6.5 2.95 Z M5.85 5.9 H7.15 V10.1 H5.85 Z"/>
                    </graphic>
                </Label>
            </top>
            <right>
                <HBox styleClass="main-right-container" BorderPane.alignment="CENTER">
                    <children>
                        <VerticallyFilledPane fx:id="propertiesSlideoutTrayPane" styleClass="slideout-tray-pane"/>
                        <VerticallyFilledPane fx:id="timelineSlideoutTrayPane" styleClass="slideout-tray-pane"/>
                    </children>
                </HBox>
            </right>
            <center>
                <BorderPane prefWidth="762.0" styleClass="main-center-container" BorderPane.alignment="CENTER">
                    <center>
                        <VBox focusTraversable="true" maxHeight="1.7976931348623157E308" prefWidth="762.0">
                            <children>
                                <HBox layoutX="14.0" layoutY="135.0" prefWidth="711.0" VBox.vgrow="ALWAYS">
                                        <SplitPane fx:id="mainContent" orientation="VERTICAL" HBox.hgrow="ALWAYS"/>
                                </HBox>
                            </children>
                        </VBox>
                    </center>
                    <top>
                        <BorderPane prefWidth="894.0" styleClass="concept-detail-banner-background"
                                    BorderPane.alignment="CENTER">
                            <center>
                                <GridPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                          prefWidth="510.0">
                                    <styleClass>
                                        <String fx:value="concept-detail-banner-background"/>
                                        <String fx:value="window-banner-grid"/>
                                    </styleClass>
                                    <columnConstraints>
                                        <ColumnConstraints halignment="LEFT" maxWidth="586.0" minWidth="-Infinity"
                                                           prefWidth="42.0"/>
                                        <ColumnConstraints halignment="LEFT" maxWidth="586.0" minWidth="234.0"
                                                           prefWidth="416.0"/>
                                        <ColumnConstraints/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints vgrow="NEVER"/>
                                        <RowConstraints maxHeight="77.0" minHeight="0.0"
                                                        vgrow="SOMETIMES"/>
                                    </rowConstraints>
                                    <children>
                                        <PublicIDListControl fx:id="identifierControl"
                                                             styleClass="concept-definition-title"
                                                             GridPane.columnIndex="0" GridPane.columnSpan="3"
                                                             GridPane.halignment="LEFT" GridPane.rowIndex="1"
                                                             GridPane.valignment="TOP"/>
                                        <ComponentItemNode fx:id="windowConceptTitle"
                                                           maxHeight="1.7976931348623157E308" prefWidth="416.0"
                                                           styleClass="window-main-title"
                                                           wrapText="true" GridPane.columnIndex="0">
                                            <tooltip>
                                                <Tooltip fx:id="windowConceptTitleTooltip" text="Empty Tooltip"/>
                                            </tooltip>
                                        </ComponentItemNode>
                                    </children>
                                </GridPane>
                            </center>
                            <right>
                                <StackPane prefWidth="210.0" BorderPane.alignment="CENTER">
                                    <BorderPane.margin>
                                        <Insets bottom="5" right="5" top="5"/>
                                    </BorderPane.margin>
                                    <StampViewControl fx:id="stampViewControl" prefWidth="210.0"/>
                                </StackPane>
                            </right>
                        </BorderPane>
                    </top>
                </BorderPane>
            </center>
        </BorderPane>
            </center>
        </BorderPane>
    </center>
    <styleClass>
        <String fx:value="concept-detail-pane"/>
        <String fx:value="lidr-container"/>
        <String fx:value="pattern-window"/>
        <String fx:value="gen-purpose-window" />
    </styleClass>
</BorderPane>