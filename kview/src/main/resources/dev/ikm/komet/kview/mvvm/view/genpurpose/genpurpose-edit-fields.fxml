<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="146.0" prefWidth="500.0" styleClass="sub-container" stylesheets="@../kview.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.ikm.komet.kview.mvvm.view.genpurpose.GenPurposeFieldsController">
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
         </BorderPane.margin>
         <content>
            <VBox styleClass="controls-container" fx:id="editFieldsVBox" />
         </content>
      </ScrollPane>
   </center>
   <top>
      <HBox styleClass="fields-title-bar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="lidr-device-title-label" text="Pattern Fields" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox styleClass="button-bar">
         <children>
            <Button fx:id="cancelButton" minWidth="-Infinity" mnemonicParsing="false" onAction="#cancel" text="Cancel" HBox.hgrow="ALWAYS" />
            <Region maxWidth="1.7976931348623157E308" prefWidth="150.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="clearOrResetFormButton" minWidth="-Infinity" mnemonicParsing="false" onAction="#clearOrResetForm" text="Clear form" />
            <Button fx:id="submitButton" minWidth="-Infinity" mnemonicParsing="false" onAction="#submit" styleClass="primary" text="Submit" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
